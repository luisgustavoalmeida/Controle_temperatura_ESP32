build/
**/build/
*.hex
*.elf
*.map
*.bin
*.eep
*.lss
*.sym
*.su
*.d

# --- Binários e objetos soltos ---
*.o
*.a
*.out

# --- VS Code / Cursor (caminhos e caches por máquina) ---
.vscode/.browse.c_cpp.db*
.vscode/ipch/
.vscode/c_cpp_properties.json
.vscode/launch.json
.vscode/tasks.json
