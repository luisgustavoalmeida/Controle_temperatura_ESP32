# =============================================================================
# Controle_temperatura_ESP32 — artefatos de build e ambiente local
# =============================================================================

# --- PlatformIO (raiz e testes_hardware/*/) ---
.pio/
**/.pio/
compile_commands.json

# --- Arduino IDE / arduino-cli ---
build/
**/build/
*.hex
*.elf
*.map
*.bin
*.eep
*.lss
*.sym
*.su
*.d

# --- Binários e objetos soltos ---
*.o
*.a
*.out

# --- VS Code / Cursor (configuração local do editor) ---
.vscode/
*.code-workspace

# --- Cursor (estado local da sessão) ---
.cursor/

# --- clangd / IntelliSense (gerado localmente) ---
.cache/

# --- Logs e temporários ---
*.log
*.tmp
*~
*.swp
*.swo

# --- Windows ---
Thumbs.db
ehthumbs.db
Desktop.ini
$RECYCLE.BIN/

# --- macOS ---
.DS_Store
.AppleDouble
.LSOverride

# --- Microsoft Office (lock de edição e fonte Word) ---
~$*
*.docx

# --- Rascunhos locais (não fazem parte do firmware) ---
post_linkedin

# --- Segredos (Wi-Fi, credenciais — se criar no futuro) ---
.env
.env.*
secrets.h
wifi_config.h
