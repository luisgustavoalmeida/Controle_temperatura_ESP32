# --- Cursor (estado local da sessão) ---
.cursor/

# --- Logs e temporários ---
*.log
*.tmp
*~
*.swp
*.swo

# --- Windows ---
Thumbs.db
ehthumbs.db
Desktop.ini
$RECYCLE.BIN/

# --- macOS ---
.DS_Store
.AppleDouble
.LSOverride

